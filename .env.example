# Environment Variables for Auto Tool Discovery System

# GitHub MCP Server Configuration
# Create a GitHub Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=your_github_personal_access_token_here

# Brave Search API Configuration
# Get your API key from: https://api.search.brave.com/app/keys
BRAVE_API_KEY=your_brave_api_key_here

# PostgreSQL Connection Configuration
# Format: postgresql://username:password@host:port/database
POSTGRES_CONNECTION_STRING=postgresql://auto_tool_user:auto_tool_pass@localhost:5432/auto_tool_disc

# Optional: OpenWeather API Key for Weather MCP
# Get your API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Logging Configuration (optional)
LOG_LEVEL=INFO

# Learning System Configuration (optional)
LEARNING_RATE=0.1
DISCOUNT_FACTOR=0.9
EPSILON=0.2