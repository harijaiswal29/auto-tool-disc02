  "edge_cases": [
    {
      "query_id": "edge001",
      "query": "",
      "description": "Empty query",
      "expected_behavior": "Handle gracefully, possibly ask for clarification"
    },
    {
      "query_id": "edge002",
      "query": "Do something with the thing",
      "description": "Vague query with unclear intent",
      "expected_behavior": "Low confidence score, request clarification"
    },
    {
      "query_id": "edge003",
      "query": "Find all files and delete them and create new ones and update the database and check the weather",
