{
  "project": {
    "name": "Autonomous Tool Discovery System",
    "version": "0.1.0",
    "author": "Your Name",
    "description": "AI agents that autonomously discover and integrate tools using MCP"
  },
  
  "logging": {
    "level": "INFO",
    "log_dir": "data/logs",
    "max_file_size_mb": 10,
    "backup_count": 5
  },
  
  "database": {
    "tool_registry": "data/registry/tools.db",
    "learning_data": "data/registry/learning.db"
  },
  
  "mcp_servers": {
    "filesystem": {
      "command": ["./node_modules/.bin/mcp-server-filesystem"],
      "args": ["/tmp"],
      "enabled": true
    },
    "brave_search": {
      "command": ["./node_modules/.bin/mcp-server-brave-search"],
      "args": [],
      "enabled": true,
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "postgres": {
      "command": ["./node_modules/.bin/mcp-server-postgres"],
      "args": ["${POSTGRES_CONNECTION_STRING}"],
      "enabled": true,
      "config": {
        "connection_string": "${POSTGRES_CONNECTION_STRING}",
        "default_connection": "postgresql://auto_tool_user:auto_tool_pass@localhost:5432/auto_tool_disc"
      },
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      }
    },
    "github": {
      "command": ["./node_modules/.bin/mcp-server-github"],
      "args": [],
      "enabled": true,
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "financial_datasets": {
      "type": "remote",
      "endpoint": "https://api.financialdatasets.ai/mcp/v1",
      "auth_type": "api_key",
      "enabled": true,
      "env": {
        "FINANCIAL_DATASETS_API_KEY": "${FINANCIAL_DATASETS_API_KEY}"
      }
    },
    "zerodha": {
      "type": "remote",
      "endpoint": "https://api.kite.trade/mcp/v1",
      "auth_type": "oauth",
      "enabled": true,
      "env": {
        "ZERODHA_API_KEY": "${ZERODHA_API_KEY}",
        "ZERODHA_API_SECRET": "${ZERODHA_API_SECRET}",
        "ZERODHA_ACCESS_TOKEN": "${ZERODHA_ACCESS_TOKEN}"
      },
      "config": {
        "use_sandbox": false,
        "sandbox_endpoint": "https://sandbox.kite.trade/mcp/v1",
        "cache_ttl": 60,
        "session_expiry": "daily"
      }
    },
    "notion": {
      "type": "remote",
      "endpoint": "https://api.notion.com/mcp/v1",
      "command": ["npx", "-y", "@notionhq/notion-mcp-server"],
      "auth_type": "integration_token",
      "enabled": true,
      "env": {
        "NOTION_INTEGRATION_TOKEN": "${NOTION_INTEGRATION_TOKEN}",
        "NOTION_MCP_ENDPOINT": "${NOTION_MCP_ENDPOINT}"
      },
      "config": {
        "api_version": "2022-06-28",
        "cache_ttl": 300,
        "markdown_export": true,
        "max_page_size": 100
      }
    }
  },
  
  "learning": {
    "algorithm": "q_learning",
    "parameters": {
      "learning_rate": 0.1,
      "discount_factor": 0.9,
      "epsilon": 0.2,
      "epsilon_decay": 0.995,
      "min_epsilon": 0.01
    }
  },
  
  "q_learning": {
    "learning_rate": 0.1,
    "discount_factor": 0.9,
    "exploration_rate": 0.2,
    "exploration_decay": 0.995,
    "min_exploration_rate": 0.01,
    "max_tools": 3,
    "buffer_capacity": 10000,
    "batch_size": 32,
    "update_frequency": 4,
    "enable_learning": true
  },
  
  "dqn": {
    "enabled": false,
    "network_type": "standard",
    "network_architecture": [512, 256, 128],
    "dropout_rate": 0.2,
    "learning_rate": 0.0001,
    "discount_factor": 0.99,
    "tau": 0.001,
    "target_update_frequency": 1000,
    "double_dqn": true,
    "dueling_dqn": false,
    "noisy_std_init": 0.5,
    "gradient_clip": 1.0,
    "batch_size": 64,
    "memory_size": 100000,
    "exploration_rate": 0.1,
    "exploration_decay": 0.995,
    "min_exploration_rate": 0.01,
    "prioritized_replay": true,
    "prioritized_replay_alpha": 0.6,
    "prioritized_replay_beta": 0.4,
    "prioritized_replay_beta_increment": 0.001,
    "device": "auto"
  },
  
  "intent_recognition": {
    "model": "all-MiniLM-L6-v2",
    "similarity_threshold": 0.7,
    "confidence_threshold": 0.7,
    "cache_size": 1000,
    "enable_state_tracking": true,
    "enable_persistence": true,
    "text_preprocessor": {
      "expand_contractions": true,
      "remove_special_chars": true,
      "normalize_whitespace": true
    },
    "tokenizer": {
      "detect_questions": true,
      "max_tokens": 500
    },
    "intent_classifier": {
      "keyword_weight": 0.3,
      "semantic_weight": 0.4,
      "context_weight": 0.3
    },
    "context_enricher": {
      "max_history": 10,
      "session_timeout_minutes": 30
    },
    "confidence_scorer": {
      "feature_weights": {
        "semantic_similarity": 0.4,
        "keyword_match": 0.3,
        "context_relevance": 0.2,
        "historical_accuracy": 0.1
      }
    },
    "state_manager": {
      "enable_transitions": true,
      "timeout_seconds": 300,
      "max_retries": 3
    },
    "multi_intent": {
      "enabled": true,
      "max_intents_per_query": 5,
      "separators": [" and ", " then ", " also ", " plus ", ". ", "; "]
    }
  },
  
  "evaluation": {
    "metrics": ["accuracy", "response_time", "tool_efficiency"],
    "baseline_comparison": true,
    "experiment_repetitions": 5
  },
  
  "orchestration": {
    "max_tools_per_query": 3,
    "tool_selection_strategy": "performance_weighted",
    "parallel_execution": true,
    "execution_timeout": 30
  },
  
  "tool_discovery": {
    "semantic_weight": 0.3,
    "capability_weight": 0.3,
    "performance_weight": 0.2,
    "relationship_weight": 0.2,
    "min_score_threshold": 0.3,
    "cache_size": 1000
  },
  
  "retry_policies": {
    "default": {
      "type": "exponential_backoff",
      "max_attempts": 5,
      "base_delay": 1.0,
      "max_delay": 16.0,
      "jitter_factor": 0.2
    },
    "mcp_servers": {
      "filesystem": {
        "type": "exponential_backoff",
        "max_attempts": 3,
        "base_delay": 0.5,
        "max_delay": 8.0,
        "jitter_factor": 0.1
      },
      "brave_search": {
        "type": "exponential_backoff",
        "max_attempts": 5,
        "base_delay": 2.0,
        "max_delay": 30.0,
        "jitter_factor": 0.3
      },
      "postgres": {
        "type": "exponential_backoff",
        "max_attempts": 3,
        "base_delay": 1.0,
        "max_delay": 10.0,
        "jitter_factor": 0.2
      },
      "github": {
        "type": "exponential_backoff",
        "max_attempts": 5,
        "base_delay": 2.0,
        "max_delay": 60.0,
        "jitter_factor": 0.3
      },
      "financial_datasets": {
        "type": "exponential_backoff",
        "max_attempts": 5,
        "base_delay": 2.0,
        "max_delay": 30.0,
        "jitter_factor": 0.3
      },
      "zerodha": {
        "type": "exponential_backoff",
        "max_attempts": 5,
        "base_delay": 1.0,
        "max_delay": 20.0,
        "jitter_factor": 0.2
      },
      "notion": {
        "type": "exponential_backoff",
        "max_attempts": 5,
        "base_delay": 1.5,
        "max_delay": 30.0,
        "jitter_factor": 0.25
      }
    },
    "no_retry_errors": [
      "NonRetryableError",
      "AuthenticationError",
      "InvalidArgumentError"
    ]
  },
  
  "circuit_breaker": {
    "default": {
      "failure_threshold": 5,
      "recovery_timeout": 30.0,
      "half_open_test_requests": 3
    },
    "mcp_servers": {
      "filesystem": {
        "failure_threshold": 3,
        "recovery_timeout": 10.0,
        "half_open_test_requests": 2
      },
      "brave_search": {
        "failure_threshold": 5,
        "recovery_timeout": 60.0,
        "half_open_test_requests": 3
      },
      "postgres": {
        "failure_threshold": 3,
        "recovery_timeout": 20.0,
        "half_open_test_requests": 2
      },
      "github": {
        "failure_threshold": 5,
        "recovery_timeout": 120.0,
        "half_open_test_requests": 3
      },
      "financial_datasets": {
        "failure_threshold": 5,
        "recovery_timeout": 60.0,
        "half_open_test_requests": 3
      },
      "zerodha": {
        "failure_threshold": 5,
        "recovery_timeout": 30.0,
        "half_open_test_requests": 3
      },
      "notion": {
        "failure_threshold": 5,
        "recovery_timeout": 45.0,
        "half_open_test_requests": 3
      }
    }
  },
  
  "connection_pool": {
    "max_connections": 10,
    "connection_timeout": 5.0,
    "idle_timeout": 300.0,
    "health_check_interval": 60.0
  },
  
  "reward_calculation": {
    "base_weights": {
      "success": 1.0,
      "failure": -0.5,
      "partial_success": 0.3
    },
    "failure_penalties": {
      "network_timeout": -0.2,
      "permission_error": -0.8,
      "rate_limit": -0.3,
      "connection_error": -0.25,
      "retryable": -0.1,
      "non_retryable": -0.7,
      "unknown": -0.5
    },
    "resource_penalties": {
      "memory_weight": 0.05,
      "cpu_weight": 0.05,
      "api_calls_weight": 0.1,
      "time_weight": 0.1
    },
    "synergy_bonuses": {
      "known_good_combo": 0.2,
      "discovered_combo": 0.3,
      "complementary_tools": 0.15
    },
    "context_multipliers": {
      "exploration": 1.2,
      "production": 0.8,
      "high_confidence": 1.0,
      "low_confidence": 1.1,
      "user_initiated": 1.0,
      "system_initiated": 0.9
    }
  },
  
  "advanced_reward_strategies": {
    "enabled": true,
    "combination_method": "weighted_average",
    "ab_testing_enabled": false,
    "strategy_weights": {
      "temporal": 0.25,
      "hierarchical": 0.25,
      "adaptive": 0.25,
      "information_theoretic": 0.25
    },
    "strategies": {
      "temporal_difference": {
        "enabled": true,
        "lambda": 0.9,
        "n_steps": 5,
        "gamma": 0.9,
        "use_gae": false
      },
      "hierarchical": {
        "enabled": true,
        "goal_weights": {
          "primary": 1.0,
          "secondary": 0.5,
          "tertiary": 0.25,
          "milestone": 0.4,
          "subtask": 0.1
        },
        "milestone_bonus": 0.5,
        "progress_reward": true,
        "subtask_completion_threshold": 0.8
      },
      "adaptive_shaping": {
        "enabled": true,
        "adaptation_rate": 0.01,
        "curriculum_stages": 3,
        "performance_window": 100,
        "meta_learning_rate": 0.001
      },
      "information_theoretic": {
        "enabled": true,
        "curiosity_weight": 0.1,
        "entropy_bonus": 0.05,
        "novelty_threshold": 0.7,
        "state_visit_decay": 0.99,
        "mutual_info_weight": 0.15
      },
      "risk_aware": {
        "enabled": false,
        "var_confidence": 0.95,
        "cvar_tail": 0.1
      },
      "meta_learning": {
        "enabled": false,
        "transfer_bonus": 0.2,
        "few_shot_threshold": 5
      }
    }
  }
}