{
  "project": {
    "name": "Autonomous Tool Discovery System",
    "version": "0.1.0",
    "author": "Your Name",
    "description": "AI agents that autonomously discover and integrate tools using MCP"
  },
  
  "logging": {
    "level": "INFO",
    "log_dir": "data/logs",
    "max_file_size_mb": 10,
    "backup_count": 5
  },
  
  "database": {
    "tool_registry": "data/registry/tools.db",
    "learning_data": "data/registry/learning.db"
  },
  
  "mcp_servers": {
    "filesystem": {
      "command": ["./node_modules/.bin/mcp-server-filesystem"],
      "args": ["/tmp"],
      "enabled": true
    },
    "brave_search": {
      "command": ["./node_modules/.bin/mcp-server-brave-search"],
      "args": [],
      "enabled": true,
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "postgres": {
      "command": ["./node_modules/.bin/mcp-server-postgres"],
      "args": ["${POSTGRES_CONNECTION_STRING}"],
      "enabled": true,
      "config": {
        "connection_string": "${POSTGRES_CONNECTION_STRING}",
        "default_connection": "postgresql://auto_tool_user:auto_tool_pass@localhost:5432/auto_tool_disc"
      },
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      }
    },
    "github": {
      "command": ["./node_modules/.bin/mcp-server-github"],
      "args": [],
      "enabled": true,
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  },
  
  "learning": {
    "algorithm": "q_learning",
    "parameters": {
      "learning_rate": 0.1,
      "discount_factor": 0.9,
      "epsilon": 0.2,
      "epsilon_decay": 0.995,
      "min_epsilon": 0.01
    }
  },
  
  "q_learning": {
    "learning_rate": 0.1,
    "discount_factor": 0.9,
    "exploration_rate": 0.2,
    "exploration_decay": 0.995,
    "min_exploration_rate": 0.01,
    "max_tools": 3,
    "buffer_capacity": 10000,
    "batch_size": 32,
    "update_frequency": 4,
    "enable_learning": true
  },
  
  "intent_recognition": {
    "model": "all-MiniLM-L6-v2",
    "similarity_threshold": 0.7,
    "confidence_threshold": 0.7,
    "cache_size": 1000,
    "enable_state_tracking": true,
    "enable_persistence": true,
    "text_preprocessor": {
      "expand_contractions": true,
      "remove_special_chars": true,
      "normalize_whitespace": true
    },
    "tokenizer": {
      "detect_questions": true,
      "max_tokens": 500
    },
    "intent_classifier": {
      "keyword_weight": 0.3,
      "semantic_weight": 0.4,
      "context_weight": 0.3
    },
    "context_enricher": {
      "max_history": 10,
      "session_timeout_minutes": 30
    },
    "confidence_scorer": {
      "feature_weights": {
        "semantic_similarity": 0.4,
        "keyword_match": 0.3,
        "context_relevance": 0.2,
        "historical_accuracy": 0.1
      }
    },
    "state_manager": {
      "enable_transitions": true,
      "timeout_seconds": 300,
      "max_retries": 3
    },
    "multi_intent": {
      "enabled": true,
      "max_intents_per_query": 5,
      "separators": [" and ", " then ", " also ", " plus ", ". ", "; "]
    }
  },
  
  "evaluation": {
    "metrics": ["accuracy", "response_time", "tool_efficiency"],
    "baseline_comparison": true,
    "experiment_repetitions": 5
  },
  
  "orchestration": {
    "max_tools_per_query": 3,
    "tool_selection_strategy": "performance_weighted",
    "parallel_execution": true,
    "execution_timeout": 30
  },
  
  "tool_discovery": {
    "semantic_weight": 0.3,
    "capability_weight": 0.3,
    "performance_weight": 0.2,
    "relationship_weight": 0.2,
    "min_score_threshold": 0.3,
    "cache_size": 1000
  },
  
  "retry_policies": {
    "default": {
      "type": "exponential_backoff",
      "max_attempts": 5,
      "base_delay": 1.0,
      "max_delay": 16.0,
      "jitter_factor": 0.2
    },
    "mcp_servers": {
      "filesystem": {
        "type": "exponential_backoff",
        "max_attempts": 3,
        "base_delay": 0.5,
        "max_delay": 8.0,
        "jitter_factor": 0.1
      },
      "brave_search": {
        "type": "exponential_backoff",
        "max_attempts": 5,
        "base_delay": 2.0,
        "max_delay": 30.0,
        "jitter_factor": 0.3
      },
      "postgres": {
        "type": "exponential_backoff",
        "max_attempts": 3,
        "base_delay": 1.0,
        "max_delay": 10.0,
        "jitter_factor": 0.2
      },
      "github": {
        "type": "exponential_backoff",
        "max_attempts": 5,
        "base_delay": 2.0,
        "max_delay": 60.0,
        "jitter_factor": 0.3
      }
    },
    "no_retry_errors": [
      "NonRetryableError",
      "AuthenticationError",
      "InvalidArgumentError"
    ]
  },
  
  "circuit_breaker": {
    "default": {
      "failure_threshold": 5,
      "recovery_timeout": 30.0,
      "half_open_test_requests": 3
    },
    "mcp_servers": {
      "filesystem": {
        "failure_threshold": 3,
        "recovery_timeout": 10.0,
        "half_open_test_requests": 2
      },
      "brave_search": {
        "failure_threshold": 5,
        "recovery_timeout": 60.0,
        "half_open_test_requests": 3
      },
      "postgres": {
        "failure_threshold": 3,
        "recovery_timeout": 20.0,
        "half_open_test_requests": 2
      },
      "github": {
        "failure_threshold": 5,
        "recovery_timeout": 120.0,
        "half_open_test_requests": 3
      }
    }
  },
  
  "connection_pool": {
    "max_connections": 10,
    "connection_timeout": 5.0,
    "idle_timeout": 300.0,
    "health_check_interval": 60.0
  },
  
  "reward_calculation": {
    "base_weights": {
      "success": 1.0,
      "failure": -0.5,
      "partial_success": 0.3
    },
    "failure_penalties": {
      "network_timeout": -0.2,
      "permission_error": -0.8,
      "rate_limit": -0.3,
      "connection_error": -0.25,
      "retryable": -0.1,
      "non_retryable": -0.7,
      "unknown": -0.5
    },
    "resource_penalties": {
      "memory_weight": 0.05,
      "cpu_weight": 0.05,
      "api_calls_weight": 0.1,
      "time_weight": 0.1
    },
    "synergy_bonuses": {
      "known_good_combo": 0.2,
      "discovered_combo": 0.3,
      "complementary_tools": 0.15
    },
    "context_multipliers": {
      "exploration": 1.2,
      "production": 0.8,
      "high_confidence": 1.0,
      "low_confidence": 1.1,
      "user_initiated": 1.0,
      "system_initiated": 0.9
    }
  }
}